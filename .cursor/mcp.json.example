{
  "mcpServers": {
    "solar-ai-optimizer": {
      "command": "docker",
      "args": [
        "compose",
        "--profile",
        "mcp",
        "-f",
        "${workspaceFolder}/docker-compose.yml",
        "run",
        "--rm",
        "--no-TTY",
        "mcp-stdio"
      ],
      "env": {
        "MCP_TOKEN": "${env:SOLAR_MCP_TOKEN}"
      }
    }
  }
}
