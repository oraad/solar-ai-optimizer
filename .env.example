# OPTIONAL. The app needs NO .env and NO config.yaml to run: configure
# everything (including the Home Assistant URL/token) from the dashboard
# Settings panel, which persists to the data volume. This file just documents
# the environment variables you MAY set (e.g. via docker-compose `environment:`)
# if you prefer env-based config. Copy to .env only if you want to use it.

# --- Home Assistant connection (optional; can also be set in the UI) ---
# HA_BASE_URL=http://homeassistant.local:8123
# HA_TOKEN=replace-with-long-lived-token
# HA_VERIFY_SSL=true

# --- App behaviour ---
# DATA_DIR=/app/data
# DATABASE_URL=sqlite+aiosqlite:////app/data/solar.db
# SHADOW MODE: when true, the engine logs decisions but performs NO writes.
# SHADOW_MODE=true
# LOG_LEVEL=INFO

# --- Standalone API protection (optional) ---
# When set, mutating /api/* requests require: Authorization: Bearer <token>
# Set the same value in Settings → API security (stored in this browser).
# WebSocket /ws also requires ?token= or Bearer when API_TOKEN is set.
# API_TOKEN=

# --- CORS (standalone dev; comma-separated origins, default *) ---
# CORS_ORIGINS=*

# --- Optional: Solcast (leave blank to use free Open-Meteo) ---
# SOLCAST_API_KEY=
# SOLCAST_RESOURCE_ID=

# --- Optional: ML load forecasting (Phase 4, needs scikit-learn) ---
# ML_LOAD_ENABLED=false

# --- Optional: local LLM assistant (Phase 4) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# LLM_ENABLED=false
