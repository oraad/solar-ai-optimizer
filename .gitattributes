# Normalize text files to LF on checkout/commit (avoids VERSION CRLF breaking release CI).
* text=auto eol=lf

# Shell entrypoints must stay LF for Linux containers.
*.sh text eol=lf
run.sh text eol=lf

# Canonical version files — release workflows compare tags on Linux.
VERSION text eol=lf
INTEGRATION_VERSION text eol=lf
