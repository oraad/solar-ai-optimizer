{
  "Id": "abc123",
  "Image": "sha256:oldimage",
  "Config": {
    "Image": "ghcr.io/oraad/solar-ai-optimizer:0.5.10",
    "Entrypoint": ["/app/run.sh"],
    "Cmd": [],
    "Env": [
      "PATH=/usr/local/bin:/usr/bin:/bin",
      "SHADOW_MODE=true",
      "LOG_LEVEL=INFO",
      "SELF_UPDATE_ENABLED=true",
