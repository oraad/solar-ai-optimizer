{
  "name": "solar-ai-optimizer-dashboard",
  "version": "0.6.11",
  "description": "Lit dashboard for the Solar AI Optimizer",
  "type": "module",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "docs:screenshots": "tsx scripts/capture-screenshots.mts",
    "docs:screenshots:docker": "docker compose -f ../docker-compose.yml --profile docs run --rm docs-screenshots",
    "test:charts-visual": "tsx scripts/verify-charts.mts",
    "test:charts-visual:docker": "docker compose -f ../docker-compose.yml --profile docs run --rm docs-screenshots npm run test:charts-visual"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "lit": "^3.3.3",
    "marked": "^18.0.5",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "jsdom": "^29.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.0",
    "vite": "^8.1.3",
    "vite-plugin-compression2": "^2.5.3",
    "vitest": "^4.1.0"
  }
}
